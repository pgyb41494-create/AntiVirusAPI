# Railway auto-injects when you add PostgreSQL
DATABASE_URL=postgresql://user:pass@host:5432/railway

# Shared secret — simulator sends this as x-api-key header
SIMULATOR_API_KEY=change-me-simulator-secret

# Bot uses this to poll /api/events?since_id=
BOT_API_KEY=change-me-bot-secret

# Comma-separated allowed origins (your Vercel URL)
CORS_ORIGINS=https://your-site.vercel.app,http://localhost:3000

# Optional fallback if you host the exe elsewhere instead of PUT /api/simulator/release
# SIMULATOR_RELEASE_URL=https://example.com/SZCTrap.exe

# Railway sets PORT automatically
PORT=8000
